class Solution {
   
        final int [][]difference={{-1,0},{1,0},{0,1},{0,-1}};
        private void DFS(char[][] grid,int R,int C,int row,int col){
            grid[row][col]='0';
            for(int i=0;i<4;i++){
                int ar=row+difference[i][0];
                int ac=col+difference[i][1];
                if(ar>=0&&ar<R&&ac>=0&&ac<C&&grid[ar][ac]=='1'){
                    DFS(grid,R,C,ar,ac);
                }
            }
        }
        public int numIslands(char[][] grid) {
            int R=grid.length;
            int C=grid[0].length;
            int island=0;
            for(int row=0;row<R;row++){
                for(int col=0;col<C;col++){
                    if(grid[row][col]=='1'){
                        island++;
                        DFS(grid,R,C,row,col);
                    }
                    }
                }
                return island;
            }

    

}
