#include<iostream>
#include<algorithm>
using namespace std;
int main(){
    int a,b;
    cin>>a>>b;
    int x[a];
    int y[b];
    for(int i=0;i<a;i++){
        cin>>x[i];
    }
    for(int i=0;i<b;i++){
        cin>>y[i];
    }
    sort(x,x+a);
    sort(y,y+b);
    int count=0;
    
    int i=0,j=0;
    while(i<a&&j<b){
        if(y[j]<=2*x[i]){
            count++;
            i++;j++;
        }
        else{
            i++;
        }
    }
    cout<<count;
}
